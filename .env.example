# Atlas Note environment example
# Copy this file to .env for local-only settings.
# Do not commit real API keys, passwords, tokens, or personal data.

# AI provider settings
AI_PROVIDER=
AI_API_KEY=
AI_MODEL=

# WebDAV sync settings
WEBDAV_ENDPOINT=
WEBDAV_USERNAME=
WEBDAV_PASSWORD=

# Local storage settings
ATLAS_NOTE_DATA_DIR=

